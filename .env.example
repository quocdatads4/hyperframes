# No environment variables required for basic usage.
# Run `bun run dev` to start the studio, `npx hyperframes render` to render video.

# Optional integrations:
# GEMINI_API_KEY=        # AI image captioning during website capture (~$0.001/image, https://aistudio.google.com/apikey)

# Required by the deployed data-driven Studio runtime:
DATFRAMES_API_URL=https://frames-api.example.com
DATFRAMES_STUDIO_SERVICE_TOKEN=replace-with-the-same-long-random-service-token
DATFRAMES_API_TIMEOUT_MS=30000
HYPERFRAMES_PROJECT_CACHE_ROOT=/tmp/hyperframes-projects
HYPERFRAMES_PROJECT_ARCHIVE_MAX_BYTES=52428800
